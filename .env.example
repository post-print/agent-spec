# Required for live Cursor SDK runs (--live) and judge classifiers.
# Export into the shell (e.g. `export CURSOR_API_KEY=...`); agent-test does not auto-load this file.
CURSOR_API_KEY=

# Required for live Claude Code runs (--live --host claude). Judge still needs CURSOR_API_KEY unless --no-judge.
# ANTHROPIC_API_KEY=
# Optional Claude Code overrides:
# CLAUDE_CODE_BIN=
# CLAUDE_AGENT_MODEL=
# CLAUDE_CODE_ALLOWED_TOOLS=Bash,Read,Edit,Write,Glob,Grep,Agent

# Optional agent-test knobs (see packages/test/README.md)
# AGENT_TEST_DEBUG=1
# AGENT_TEST_VERBOSE=1
# AGENT_TEST_VERBOSE_PATHS=1
# AGENT_TEST_QUIET=1
# AGENT_TEST_TIMEOUT_MS=600000
# AGENT_TEST_ALLOW_IN_PLACE=1
# AGENT_TEST_NO_WORKTREE=1
# AGENT_TEST_NO_ISOLATE=1
# AGENT_TEST_SCENARIO_SETTLE_MS=0
# AGENT_TEST_LIVE_RETRIES=3
# AGENT_TEST_SCENARIO_RETRIES=1
# CURSOR_AGENT_MODEL=
# CURSOR_JUDGE_MODEL=
# CURSOR_JUDGE_TEMPERATURE=
