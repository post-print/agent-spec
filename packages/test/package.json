{
	"name": "@post-print/agent-test",
	"version": "0.1.17",
	"type": "module",
	"bin": {
		"agent-test": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bunx tsc --build",
		"typecheck": "bunx tsc --build",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check . --write",
		"test": "vitest run",
		"test:sandbox-safe": "vitest run --exclude 'src/**/scenario-seed.test.ts'",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist tsconfig.tsbuildinfo"
	},
	"dependencies": {
		"@post-print/agent-harness": "workspace:*",
		"chalk": "5"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.0.17",
		"typescript": "~7.0.2",
		"vitest": "^4.0.17"
	},
	"description": "Scenario runner and CLI for agent-spec suites",
	"repository": {
		"type": "git",
		"url": "https://github.com/post-print/agent-spec.git",
		"directory": "packages/test"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
