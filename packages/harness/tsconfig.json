{
	"compilerOptions": {
		"lib": [
			"ES2022"
		],
		"target": "ES2022",
		"types": [
			"node"
		],
		"rootDir": "src",
		"outDir": "dist",
		"composite": true,
		"incremental": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"module": "ES2022",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": false,
		"noEmit": false,
		"allowImportingTsExtensions": false,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": [
		"src"
	]
}
