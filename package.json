{
	"name": "agent-spec",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.2.21",
	"engines": {
		"node": ">=22"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter '*' build",
		"dev": "bun run lint && bun run typecheck && bun run test",
		"check": "bun run lint && bun run typecheck && bun run test && bun run build",
		"test": "bun run --filter '*' test",
		"test:sandbox-safe": "bun run --filter '*' test:sandbox-safe",
		"test:coverage": "bun run --filter '*' test:coverage",
		"typecheck": "bunx tsc --build",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check . --write",
		"format": "bunx biome format --write .",
		"clean": "bun run --filter '*' clean",
		"validate:changed": "skeleton validate changed",
		"validate:ci": "skeleton validate changed --base origin/main",
		"audit:docs": "skeleton audit docs",
		"audit:skills": "skeleton audit skills",
		"audit:self": "skeleton audit self",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@csark0812/skeleton": "^1.5.3",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.0.17",
		"simple-git-hooks": "^2.13.0",
		"typescript": "~7.0.2",
		"vitest": "^4.0.17"
	},
	"overrides": {
		"undici": "6.27.0"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1"
	}
}
